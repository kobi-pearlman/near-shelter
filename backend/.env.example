# Generate VAPID keys by running: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_EMAIL=admin@near-shelter.app

# Port for the backend server (default: 3001)
PORT=3001

# Optional: HTTP proxy URL to bypass Pikud HaOref geo-blocking (Israeli IP required)
# Example: PROXY_URL=http://user:pass@proxy-host:port/
# PROXY_URL=
